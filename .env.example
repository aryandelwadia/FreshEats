# FreshEats Environment Variables Configuration
# Copy this file, rename it to .env, and fill in your actual values.

# ==========================================
# BACKEND SETTINGS (Node.js/Express)
# ==========================================
# MongoDB Connection String (e.g., MongoDB Atlas URI)
DB=mongodb+srv://your_username:your_password@cluster.mongodb.net/your_db

# Backend Server Port (Default is 3000)
PORT=3000

# URL of the hosted Frontend (Crucial for CORS to allow frontend requests)
# Example Local: http://localhost:5173
# Example Production: https://fresheats.vercel.app
FRONTEND_URL=http://localhost:5173

# Secret Keys for JWT Authentication (Create strong, random strings)
JWT_KEY=your_user_jwt_secret_key_here
SELLER_JWT_KEY=your_seller_jwt_secret_key_here
ADMIN_JWT_KEY=your_admin_jwt_secret_key_here

# ==========================================
# FRONTEND SETTINGS (React/Vite)
# ==========================================
# URL of the hosted Backend API (Used by Axios to fetch/post data)
# Note: Variables MUST start with VITE_ to be exposed to the React frontend
# Example Local: http://localhost:3000
# Example Production: https://api.fresheats.com
VITE_BACKEND_URL=http://localhost:3000